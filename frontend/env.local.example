# TwitBoost — Frontend Environment Variables
# Copy this file to .env.local and fill in values before running npm run dev
#
# NOTE: file is named env.local.example (no leading dot) to avoid
#       .gitignore blocking it. Rename to .env.local when using locally.

# URL of the FastAPI backend (no trailing slash)
# Local development: http://localhost:8000
# Railway deploy:    https://your-project.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase (Phase 2+)
# Find at: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

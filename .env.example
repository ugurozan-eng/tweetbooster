# ============================================================
# TwitBoost — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ------------------------------------------------------------
# AI (Phase 1+)
# https://aistudio.google.com/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------------------------
# Web Search (Phase 1+)
# https://brave.com/search/api/
# ------------------------------------------------------------
BRAVE_SEARCH_API_KEY=

# ------------------------------------------------------------
# Supabase (Phase 2+)
# Dashboard: https://supabase.com/dashboard/project/paqmesjmmaytwjwucfxc/settings/api
#
# SUPABASE_URL              → "Project URL" field
# SUPABASE_ANON_KEY         → publishable key (sb_publishable_* format) — "API Keys" section
# SUPABASE_SERVICE_ROLE_KEY → "service_role" key — keep secret, backend only
#
# NOTE: No JWT secret needed. JWT verification uses Supabase's JWKS endpoint
# (supports ECC P-256 keys, the default for projects created mid-2025+).
# ------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Payments — LemonSqueezy (Phase 2+)
# https://app.lemonsqueezy.com/settings/api
# VERIFY TRY currency support before enabling.
# ------------------------------------------------------------
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Product variant IDs (Dashboard → Products → [plan] → Variants → copy numeric ID)
LEMONSQUEEZY_VARIANT_NICHE_ID=
LEMONSQUEEZY_VARIANT_OPPOSITION_ID=
LEMONSQUEEZY_VARIANT_FULL_ID=

# ------------------------------------------------------------
# Twitter API (Phase 3+ — BYOK model, DEFERRED)
# https://developer.twitter.com/
# ------------------------------------------------------------
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
